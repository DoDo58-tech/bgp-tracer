import os
from pathlib import Path

PROJECT_ROOT = Path(os.path.dirname(os.path.abspath(__file__)))

# Logging configuration
LOG_LEVEL = "DEBUG"
LOG_FILE = PROJECT_ROOT / "logs" / "bgp_tracer.log"

# Data directories
DATA_DIR = PROJECT_ROOT / "data"
UPDATES_DIR = DATA_DIR / "updates_rrc00"
PREFIX2AS_DIR = DATA_DIR / "prefix2as"
ASREL_DIR = DATA_DIR / "asrel"
ASORG_DIR = DATA_DIR / "as2org"

# Cloudflare Radar API configuration
CLOUDFLARE_HTTP_TIMESERIES_AS_URL = "https://api.cloudflare.com/client/v4/radar/http/timeseries"
CLOUDFLARE_API_TOKEN = os.environ.get("CLOUDFLARE_API_TOKEN", "YOUR_CLOUDFLARE_API_TOKEN_HERE")
CLOUDFLARE_DEFAULT_AGG_INTERVAL = "15m"  
CLOUDFLARE_DEFAULT_THRESHOLD = 3.0

# LLM Configuration
BASE_URL = os.environ.get("OPENAI_BASE_URL", "https://api.deepseek.com")
MODEL = os.environ.get("OPENAI_MODEL", "deepseek-chat")
API_KEY = os.environ.get("OPENAI_API_KEY", "YOUR_API_KEY_HERE")

# Agent coordination mode - ALWAYS use LLM (agent mode)
# Removed USE_DIRECT_MODE - system must use LLM for all analysis
USE_DIRECT_MODE = False

# PathProb Configuration
# PathProb_AE integration for route leak detection
PATHPROB_AE_ROOT = os.environ.get("PATHPROB_AE_ROOT", "/data/PathProb_AE")
PATHPROB_FILE = os.environ.get("PATHPROB_FILE", None)  # If set, use this path directly

# Default search paths for pathprob.txt (in order of priority)
def _get_pathprob_search_paths():
    """Get list of paths to search for pathprob.txt file."""
    paths = []
    
    # 1. User-specified path (if set and exists)
    if PATHPROB_FILE and os.path.exists(PATHPROB_FILE):
        paths.append(Path(PATHPROB_FILE))
    
    # 2. In bgp_tracer data directory
    paths.append(PROJECT_ROOT / "data" / "pathprob" / "pathprob.txt")
    
    # 3. PathProb_AE default location (using PATHPROB_AE_ROOT)
    pathprob_ae_path = Path(PATHPROB_AE_ROOT) / "test_data" / "prob_inference" / "result" / "202506" / "pathprob.txt"
    if pathprob_ae_path not in paths:
        paths.append(pathprob_ae_path)
    
    # 4. Absolute path (fallback, only if different from #3)
    abs_path = Path("/data/PathProb_AE/test_data/prob_inference/result/202506/pathprob.txt")
    if abs_path not in paths:
        paths.append(abs_path)
    
    # 5. Parent directory relative path (only if different from #3)
    parent_path = PROJECT_ROOT.parent / "PathProb_AE" / "test_data" / "prob_inference" / "result" / "202506" / "pathprob.txt"
    if parent_path not in paths:
        paths.append(parent_path)
    
    return paths

PATHPROB_SEARCH_PATHS = _get_pathprob_search_paths()

